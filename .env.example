# Server port
PORT=3020

# Express session secret (use a long random string in production)
SESSION_SECRET=change_me_to_a_long_random_string

# Set to 'production' to enable secure cookies
NODE_ENV=development

# Field-level encryption key for task notes (AES-256-GCM).
# Must be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If omitted, notes are stored as plaintext (not recommended for production).
# ENCRYPTION_KEY=generate_a_64_char_hex_string_here

# HTTPS – set to 'true' to enable TLS (e.g. when not behind a reverse proxy/tunnel).
# When enabled, SSL_CERT and SSL_KEY must also be set.
# Defaults to false (plain HTTP, suitable for use behind Cloudflare Tunnel or another proxy).
USE_HTTPS=false
# SSL_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# SSL_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# SMTP email settings (optional — can also be configured via the admin panel).
# Used to email dropdown/flag suggestions to the administrator instead of
# storing free-text user input on the server.
# SMTP_HOST=smtp.nhs.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@nhs.net
# SMTP_PASS=your_smtp_password
# SMTP_FROM=tasker@example.com
# SMTP_TO=you@nhs.net

# Base URL for generating review links in suggestion emails.
# Set this to your publicly accessible server URL (no trailing slash).
# If omitted, suggestion emails will include a relative path instead of a
# full clickable link.
APP_URL=https://tasker.jahosi.co.uk
