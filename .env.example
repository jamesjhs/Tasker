# Server port
PORT=3020

# Express session secret (use a long random string in production)
SESSION_SECRET=change_me_to_a_long_random_string

# Set to 'production' to enable secure cookies
NODE_ENV=development

# Field-level encryption key for task notes (AES-256-GCM).
# Must be exactly 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If omitted, notes are stored as plaintext (not recommended for production).
# ENCRYPTION_KEY=generate_a_64_char_hex_string_here

# SSL – paths to Let's Encrypt certificate files.
# If both files exist the server starts in HTTPS mode automatically.
# Defaults point to /etc/letsencrypt/live/jahosi.co.uk/{fullchain,privkey}.pem
# SSL_CERT_DIR=/etc/letsencrypt/live/jahosi.co.uk
# SSL_CERT=/etc/letsencrypt/live/jahosi.co.uk/fullchain.pem
# SSL_KEY=/etc/letsencrypt/live/jahosi.co.uk/privkey.pem